{
  "name": "mdian",
  "version": "0.0.0",
  "description": "remark plugin for Obsidian Flavored Markdown",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "build": "tsc --build",
    "typecheck": "tsc --build --pretty false",
    "pretest": "pnpm run build",
    "test": "node --enable-source-maps --test dist/test/index.js",
    "coverage": "c8 --reporter=text --reporter=lcov pnpm test",
    "check": "pnpm run typecheck && pnpm test",
    "demo:dev": "pnpm --dir demo dev",
    "demo:build": "pnpm --dir demo build",
    "demo:preview": "pnpm --dir demo preview",
    "demo:typecheck": "pnpm --dir demo typecheck"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.0.0",
    "c8": "^10.1.2",
    "esbuild": "^0.28.0",
    "mdast-util-from-markdown": "^2.0.3",
    "micromark-util-chunked": "^2.0.1",
    "micromark-util-classify-character": "^2.0.1",
    "micromark-util-resolve-all": "^2.0.1",
    "micromark-util-symbol": "^2.0.1",
    "micromark-util-types": "^2.0.2",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "unified": "^11.0.0"
  },
  "dependencies": {}
}
