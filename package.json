{
  "name": "remark-ofm",
  "version": "0.0.0",
  "description": "remark plugin for Obsidian Flavored Markdown",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "types": "./dist/src/index.d.ts",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo demo/dist",
    "build": "tsc --build",
    "typecheck": "tsc --build --pretty false",
    "pretest": "pnpm run build",
    "test": "node --enable-source-maps --test dist/test/index.js",
    "coverage": "c8 --reporter=text --reporter=lcov pnpm test",
    "check": "pnpm run typecheck && pnpm test",
    "demo:dev": "vite --config vite.config.ts",
    "demo:build": "vite build --config vite.config.ts",
    "demo:preview": "vite preview --config vite.config.ts --port 4173"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "c8": "^10.1.2",
    "esbuild": "^0.28.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "unified": "^11.0.0",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.18",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-math": "^3.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "micromark-extension-math": "^3.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0"
  }
}
