{
  "name": "mdian",
  "version": "0.1.2",
  "description": "remark and rehype plugins for Obsidian Flavored Markdown",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngtrio/mdian.git"
  },
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "import": "./dist/src/react/index.js",
      "default": "./dist/src/react/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "types": "./dist/src/index.d.ts",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "build": "pnpm run clean && tsc --build && node scripts/copy-assets.mjs",
    "typecheck": "tsc --build --pretty false",
    "pretest": "pnpm run build",
    "test:node": "node --enable-source-maps --test dist/test/index.js",
    "demo:test": "vitest run --root demo --environment jsdom",
    "test": "pnpm run test:node && pnpm run demo:test",
    "coverage": "c8 --reporter=text --reporter=lcov pnpm test",
    "check": "pnpm run typecheck && pnpm test",
    "demo:dev": "pnpm run build && pnpm --dir demo dev",
    "demo:build": "pnpm run build && pnpm --dir demo build",
    "demo:preview": "pnpm --dir demo preview",
    "demo:typecheck": "pnpm run build && pnpm --dir demo typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "mdast-util-from-markdown": "^2.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "micromark-util-chunked": "^2.0.1",
    "micromark-util-classify-character": "^2.0.1",
    "micromark-util-resolve-all": "^2.0.1",
    "micromark-util-symbol": "^2.0.1",
    "micromark-util-types": "^2.0.2",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-markdown": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    }
  }
}
